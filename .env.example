# ─────────────────────────────────────────────
# Semi Autonomous Modular Agent System — Environment Config
# Copy this to .env and fill in your values.
# Then run: chmod 600 .env
# ─────────────────────────────────────────────

# ── Required ──────────────────────────────────

# Environment: "production" enforces security checks, "development" allows all chats
ENV=development

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── LLM Providers (configure at least one) ──────────────────────────────
# Kilo API Key (primary LLM provider)
KILO_API_KEY=your_kilo_api_key_here

# OpenRouter API Key (alternative provider with many model options)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Anthropic API Key (fallback option)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama base URL (for self-hosted models like Llama, Deepseek, etc.)
OLLAMA_BASE_URL=http://localhost:11434

# ── Telegram Access Control ───────────────────
# Comma-separated list of chat IDs allowed to use the bot.
# Find your chat ID by messaging @userinfobot on Telegram.
# REQUIRED when ENV=production; leave empty for development only.
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# ── LLM Settings (optional) ───────────────────
DEFAULT_MODEL=claude-sonnet-4.6
DEFAULT_MAX_TOKENS=2048

# ── Storage (optional) ────────────────────────
DB_PATH=memory/sessions.db
# DB_ENCRYPTION_KEY=your-secret-key-here  # Uncomment to enable SQLCipher encryption
MEMORY_CONTEXT_DIR=memory/context
MEMORY_SOLUTIONS_DIR=memory/solutions

# ── Local File Access (optional) ─────────────────
# Comma-separated folder paths agents are allowed to read/write.
# LOCAL_FILE_PATHS=/home/user/projects/drafts,/home/user/notes

# ── Web Tools (optional) ──────────────────────────────────────────
# Tavily API key for web search (https://app.tavily.com)
# TAVILY_API_KEY=tvly-...

# ── Extra blocked command patterns (optional) ─────────────────────
# Comma-separated regex patterns. Always blocked regardless of autonomy level.
# EXTRA_BLOCKED_PATTERNS=my-org/secret-repo,DROP TABLE

# ── Composio (optional) ───────────────────────────────────────────
# API key for Composio app integrations (Gmail, Calendar, Slack, etc.)
# COMPOSIO_API_KEY=your_composio_api_key_here
# COMPOSIO_USER_ID=default

# ── Agent Autonomy (optional) ─────────────────
# Options: read_only | supervised | autonomous
BUSINESS_AGENT_AUTONOMY=supervised
DEVOPS_AGENT_AUTONOMY=autonomous
WELLBEING_AGENT_AUTONOMY=autonomous

# ── Approval Timeouts (optional) ─────────────
# Per-action timeout in seconds. Format: ACTION_TYPE=seconds,...
# Supported types: WRITE_HIGH, EXECUTE, DESTRUCTIVE
# APPROVAL_TIMEOUTS=WRITE_HIGH=120,EXECUTE=300,DESTRUCTIVE=600

# ── Scheduler (optional) ──────────────────────
HEARTBEAT_INTERVAL_MINUTES=60

# ── HTTP interface (optional) ──────────────────
HTTP_HOST=127.0.0.1
HTTP_PORT=8080
SESSION_TTL_HOURS=24

# ── Logging (optional) ────────────────────────
LOG_LEVEL=INFO
# LOG_FORMAT=pretty   # uncomment for human-readable logs during development
LOG_FORMAT=json
